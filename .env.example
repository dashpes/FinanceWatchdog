# Optional: Email notifications via SendGrid
SENDGRID_API_KEY=

# Optional: Slack notifications
SLACK_WEBHOOK_URL=

# Discord notifications (optional)
# Create a webhook: Server Settings > Integrations > Webhooks
# You can use a single webhook for all notifications:
DISCORD_WEBHOOK_URL=
# Or use separate channels for daily vs weekly reports:
DISCORD_DAILY_WEBHOOK_URL=
DISCORD_WEEKLY_WEBHOOK_URL=

# iMessage notifications (macOS only) — the robo advisor texts you on live trades,
# run errors, and a daily summary. Recipient = your phone number (+15551234567)
# or the Apple ID email registered with iMessage. Blank disables iMessage.
# Setup: Messages.app must be signed in, and the runner (Terminal / the launchd
# job) needs Automation permission to control Messages
# (System Settings > Privacy & Security > Automation). Verify with:
#   investment-robo notify-test
IMESSAGE_TO=
# Set true to ALSO be notified on paper/dry-run placements (default: live trades only).
IMESSAGE_NOTIFY_PAPER=false

# Email (SMTP) notifications — RECOMMENDED for the robo advisor. Works from a
# headless launchd daemon (no GUI, no Messages.app, no Automation grant), so it
# keeps notifying even when nobody is logged in. Preferred over iMessage when set.
# Gmail: enable 2-Step Verification, then create an App Password
# (Google Account > Security > App passwords) and paste it as SMTP_PASSWORD.
# Leave SMTP_HOST or EMAIL_TO blank to disable email. Verify with:
#   investment-robo notify-test
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
EMAIL_USE_TLS=true

# Optional: Claude API for weekly synthesis
ANTHROPIC_API_KEY=

# Optional: Finnhub for additional data
FINNHUB_API_KEY=

# SEC EDGAR requires a real contact email in the User-Agent of every request.
# Set this to YOUR email. Blank falls back to a generic contact (works, but SEC
# may rate-limit an anonymous agent).
SEC_CONTACT_EMAIL=

# Ollama endpoint (defaults to localhost)
OLLAMA_HOST=http://localhost:11434

# Robo advisor (Public.com trading) — SECRET, keep out of config.yaml
# Generate at Public.com: Settings > Security > API (2FA required).
PUBLIC_API_TOKEN=
# Optional: override the API base URL (blank = SDK default / production).
PUBLIC_API_BASE_URL=
# Hard kill-switch for live trading, independent of config/robo.yaml.
# Must be set to false (and robo.yaml dry_run: false) to place real orders.
ROBO_FORCE_DRY_RUN=true

# Dashboard (Archie's LAN web GUI). Reads are open on your local network; the
# token is a PIN gating every mutating action (pause/kill/blocklist/settings).
# Blank token = the dashboard is strictly read-only. The Pi installer generates one.
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8321
DASHBOARD_TOKEN=
