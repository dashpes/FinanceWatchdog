# Optional: Email notifications via SendGrid
SENDGRID_API_KEY=

# Optional: Slack notifications
SLACK_WEBHOOK_URL=

# Discord notifications (optional)
# Create a webhook: Server Settings > Integrations > Webhooks
# You can use a single webhook for all notifications:
DISCORD_WEBHOOK_URL=
# Or use separate channels for daily vs weekly reports:
DISCORD_DAILY_WEBHOOK_URL=
DISCORD_WEEKLY_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# AI / LLM configuration
#
# By default the system runs COMPLETELY FREE on a local Ollama model for both
# tiers (news scoring AND weekly synthesis / research reports). Claude is
# entirely optional and only used if you opt in below.
# ---------------------------------------------------------------------------

# Ollama endpoint (defaults to localhost)
OLLAMA_HOST=http://localhost:11434

# Local models. Leave as "auto" to let the system pick models that fit this
# machine's RAM (see analysis/hardware.py), or pin an explicit tag, e.g.:
#   OLLAMA_MODEL=qwen2.5:7b            # fast tier: news relevance, sentiment, scoring
#   OLLAMA_SYNTHESIS_MODEL=qwen2.5:32b # heavier tier: weekly synthesis, research reports
OLLAMA_MODEL=auto
OLLAMA_SYNTHESIS_MODEL=auto

# Which provider handles tier-2 synthesis/reports:
#   auto      -> Claude if ANTHROPIC_API_KEY is set, else local Ollama (free)
#   ollama    -> always local (free, no API key needed)
#   anthropic -> always Claude (requires ANTHROPIC_API_KEY)
LLM_PROVIDER=auto

# Optional: Claude API. Only needed if LLM_PROVIDER=anthropic, or =auto and you
# want Claude-quality synthesis. Leave blank to stay completely free.
ANTHROPIC_API_KEY=

# Optional: Finnhub for additional data
FINNHUB_API_KEY=
