[Unit]
Description=FinanceWatchdog robo — trade run (thesis-run, gated by dry_run/kill-switch)
Documentation=https://github.com/dashpes/FinanceWatchdog
After=network-online.target ollama.service
Wants=network-online.target ollama.service

[Service]
Type=oneshot
User=@FW_USER@
WorkingDirectory=@FW_HOME@
Environment=FW_HOME=@FW_HOME@
EnvironmentFile=-@FW_HOME@/.env
# Whether an order is real depends on robo.yaml dry_run + ROBO_FORCE_DRY_RUN; the
# schedule is independent of going live. Shares robo-cron.sh's single-run lock with
# the research loop so a trade never overlaps a research cycle.
ExecStart=@FW_HOME@/scripts/robo-cron.sh thesis-run
